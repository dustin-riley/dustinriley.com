---
import dateFormat from "@/lib/utils/dateFormat";
import type { CollectionEntry } from "astro:content";

export interface Props {
  posts: CollectionEntry<"posts">[];
  showAllLink?: boolean;
  heading?: string;
}

const { posts, showAllLink = false, heading = "writing" } = Astro.props;

const monthName = (d: Date) =>
  d.toLocaleString("en-US", { month: "long", year: "numeric" });

const readMinutes = (body: string | undefined) => {
  const words = (body ?? "").trim().split(/\s+/).filter(Boolean).length;
  const mins = Math.max(1, Math.round(words / 220));
  return `${mins} min`;
};
---

<section>
  <h2 class="grid-label">{heading}</h2>
  <ul class="writing-list">
    {
      posts.map((p) => (
        <li>
          <a class="writing-item" href={`/${p.id}`}>
            <span class="date">
              {p.data.date ? monthName(p.data.date) : ""}
            </span>
            <span class="title">{p.data.title}</span>
            <span class="read-time">{readMinutes(p.body)}</span>
          </a>
        </li>
      ))
    }
  </ul>
  {
    showAllLink && (
      <p style="font-family: var(--ds-font-mono); font-size: 12px; margin-top: calc(var(--ds-space-4) * -1);">
        <a href="/writing">see all writing →</a>
      </p>
    )
  }
</section>
