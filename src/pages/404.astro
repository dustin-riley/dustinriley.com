---
import Base from "@/layouts/Base.astro";
---

<Base title="not found" noindex={true}>
  <div class="ds-container">
    <article class="ds-article" style="text-align: center;">
      <div class="article-meta">404</div>
      <h1>That page isn't around.</h1>
      <div class="article-body">
        <p>Maybe it never was. Or maybe I moved it and forgot to leave a forwarding address.</p>
        <p>
          <a href="/" class="ds-btn ds-btn-secondary">← back home</a>
        </p>
      </div>
    </article>
  </div>
</Base>
