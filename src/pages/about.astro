---
import Base from "@/layouts/Base.astro";
import social from "@/config/social.json";
import config from "@/config/config.json";

const githubUrl = social.github || "https://github.com/dustin-riley";
const email = config.contactinfo.email;
---

<Base title="about" description="A little about me.">
  <div class="ds-container">
    <article class="ds-article">
      <div class="article-meta">about</div>
      <h1>Dustin Riley</h1>
      <div class="article-body">
        <p>
          I'm a software engineer who builds small things at the edges of
          software and whatever hobby I'm deep in this month. Right now that's
          college football data, and the slow patience-sport of making things
          on the side look polished.
        </p>
        <p>
          By day I work on infrastructure and tooling. This site is the
          opposite of that — tiny, unserious, finished when I say so. It's
          where I park the experiments and occasionally write up what I
          learned making them.
        </p>
        <p>
          If you want to say hi, <a href={`mailto:${email}`}>email</a> is best.
          I'm also on
          <a href={githubUrl} rel="noopener noreferrer" target="_blank"
            >GitHub ↗</a
          > and I keep an
          <a href="/rss.xml">rss feed</a> of the writing here.
        </p>
      </div>
    </article>
  </div>
</Base>
