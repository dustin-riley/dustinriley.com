---
import config from "@/config/config.json";
import social from "@/config/social.json";
import Base from "@/layouts/Base.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("about", "-index");
if (!entry) throw new Error("Missing about content at src/content/about/-index.md");
const { Content } = await render(entry);
const { title, meta_title, description } = entry.data;

const githubUrl = social.github || "https://github.com/dustin-riley";
const email = config.contactinfo.email;
---

<Base
  title={meta_title ?? "about"}
  description={description ?? "A little about me."}
>
  <div class="ds-container">
    <article class="ds-article">
      <div class="article-meta">about</div>
      <h1>{title}</h1>
      <div class="article-body">
        <Content />
        <p>
          If you want to say hi, <a href={`mailto:${email}`}>email</a> is best. I'm
          also on
          <a href={githubUrl} rel="noopener noreferrer" target="_blank"
            >GitHub ↗</a
          > and I keep an <a href="/rss.xml">rss feed</a> of the writing here.
        </p>
      </div>
    </article>
  </div>
</Base>
