---
import Base from "@/layouts/Base.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { humanize } from "@/lib/utils/textConverter";

const categories = await getTaxonomy("posts", "categories");
---

<Base title="categories" description="Browse writing by category.">
  <div class="ds-container">
    <section class="ds-page-header">
      <p class="grid-label">categories</p>
      <h1>browse by category</h1>
      <p class="ds-lede">
        Broader groupings than tags — useful for skimming whole topic areas.
      </p>
      {
        categories.length === 0 ? (
          <p class="ds-lede">No categories yet.</p>
        ) : (
          <div class="ds-chip-cloud">
            {categories.map((category) => (
              <a class="tag-chip" href={`/categories/${category}`}>
                {humanize(category || "")}
              </a>
            ))}
          </div>
        )
      }
    </section>
  </div>
</Base>
