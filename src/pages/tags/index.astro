---
import Base from "@/layouts/Base.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { humanize } from "@/lib/utils/textConverter";

const tags = await getTaxonomy("posts", "tags");
---

<Base title="tags" description="Browse writing by tag.">
  <div class="ds-container">
    <section class="ds-page-header">
      <p class="grid-label">tags</p>
      <h1>browse by tag</h1>
      <p class="ds-lede">Every tag that shows up on a post, in one place.</p>
      {
        tags.length === 0 ? (
          <p class="ds-lede">No tags yet.</p>
        ) : (
          <div class="ds-chip-cloud">
            {tags.map((tag) => (
              <a class="tag-chip" href={`/tags/${tag}`}>
                #{humanize(tag || "")}
              </a>
            ))}
          </div>
        )
      }
    </section>
  </div>
</Base>
