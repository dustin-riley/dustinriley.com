---
import Base from "@/layouts/Base.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { humanize } from "@/lib/utils/textConverter";

const tags = await getTaxonomy("posts", "tags");
---

<Base title="tags" description="Browse writing by tag.">
  <div class="ds-container">
    <section style="padding-top: var(--ds-space-7);">
      <p class="grid-label" style="margin: 0 0 var(--ds-space-2);">tags</p>
      <h1
        style="margin: 0 0 var(--ds-space-3); font-size: var(--ds-fs-h1); font-family: var(--ds-font-display); letter-spacing: var(--ds-tracking-h1);"
      >
        browse by tag
      </h1>
      <p class="ds-lede" style="margin: 0 0 var(--ds-space-6); max-width: 620px;">
        Every tag that shows up on a post, in one place.
      </p>
      {
        tags.length === 0 ? (
          <p class="ds-lede">No tags yet.</p>
        ) : (
          <div
            style="display: flex; flex-wrap: wrap; gap: var(--ds-space-2); margin-bottom: var(--ds-space-8);"
          >
            {tags.map((tag) => (
              <a class="tag-chip" href={`/tags/${tag}`}>
                #{humanize(tag || "")}
              </a>
            ))}
          </div>
        )
      }
    </section>
  </div>
</Base>
