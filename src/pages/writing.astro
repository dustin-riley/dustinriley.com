---
import WritingList from "@/components/WritingList.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
---

<Base title="writing" description="Notes, writeups, and thinking-out-loud.">
  <div class="ds-container">
    <section style="padding-top: var(--ds-space-7);">
      <p class="grid-label" style="margin: 0 0 var(--ds-space-2);">writing</p>
      <h1 style="margin: 0 0 var(--ds-space-3); font-size: var(--ds-fs-h1); font-family: var(--ds-font-display); letter-spacing: var(--ds-tracking-h1);">
        notes and writeups
      </h1>
      <p class="ds-lede" style="margin: 0 0 var(--ds-space-6); max-width: 620px;">
        Sporatic thinking-out-loud about the things I'm building, work, and life.
      </p>
      <WritingList posts={sortedPosts} heading="" />
    </section>
  </div>
</Base>
