---
import Base from "@/layouts/Base.astro";
import WritingList from "@/components/WritingList.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import config from "@/config/config.json";

export async function getStaticPaths({ paginate }: any) {
  const posts = await getSinglePage("posts");
  const sorted = sortByDate(posts);
  return paginate(sorted, { pageSize: config.settings.pagination });
}

const { page } = Astro.props;
const pageTitle =
  page.currentPage === 1 ? "writing" : `writing · page ${page.currentPage}`;
---

<Base title={pageTitle} description="Notes, writeups, and thinking-out-loud.">
  <div class="ds-container">
    <section style="padding-top: var(--ds-space-7);">
      <p class="grid-label" style="margin: 0 0 var(--ds-space-2);">writing</p>
      <h1
        style="margin: 0 0 var(--ds-space-3); font-size: var(--ds-fs-h1); font-family: var(--ds-font-display); letter-spacing: var(--ds-tracking-h1);"
      >
        {
          page.currentPage === 1
            ? "notes and writeups"
            : `page ${page.currentPage} of ${page.lastPage}`
        }
      </h1>
      {
        page.currentPage === 1 && (
          <p
            class="ds-lede"
            style="margin: 0 0 var(--ds-space-6); max-width: 620px;"
          >
            Sporatic thinking-out-loud about the things I'm building, work, and
            life.
          </p>
        )
      }
      <WritingList posts={page.data} heading="" />
      {
        page.lastPage > 1 && (
          <nav
            style="display: flex; justify-content: space-between; font-family: var(--ds-font-mono); font-size: 12px; margin-top: var(--ds-space-5);"
            aria-label="Pagination"
          >
            <div>
              {page.url.prev && <a href={page.url.prev}>← newer</a>}
            </div>
            <div style="color: var(--ds-text-muted);">
              page {page.currentPage} of {page.lastPage}
            </div>
            <div>
              {page.url.next && <a href={page.url.next}>older →</a>}
            </div>
          </nav>
        )
      }
    </section>
  </div>
</Base>
